    "#@title ⚙️ Step 1 — Install dependencies { display-mode: \"form\" }\n",
    "print(\"Installing dependencies... (this takes 2-3 minutes first time)\")\n",
    "\n",
    "import subprocess, sys\n",
    "\n",
    "def run(cmd):\n",
    "    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)\n",
    "    if result.returncode != 0:\n",
    "        print(f\"Warning: {result.stderr[:200]}\")\n",
    "    return result\n",
    "\n",
    "# Clone TripoSG\n",
    "run(\"git clone --depth 1 https://github.com/VAST-AI-Research/TripoSG.git /content/TripoSG 2>/dev/null || echo 'Already cloned'\")\n",
    "\n",
    "# Install Python deps\n",
    "run(\"pip install -q flask flask-cors huggingface_hub transformers accelerate diffusers einops trimesh open3d omegaconf\")\n",
    "run(\"pip install -q torch torchvision --index-url https://download.pytorch.org/whl/cu118\")\n",
    "run(\"pip install -q -r /content/TripoSG/requirements.txt 2>/dev/null || true\")\n",
    "\n",
    "# Install ngrok for public URL\n",
    "run(\"pip install -q pyngrok\")\n",
    "\n",
    "print(\"✅ Dependencies installed!\")"
   ]
  },
